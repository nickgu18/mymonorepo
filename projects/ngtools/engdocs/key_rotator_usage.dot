digraph QABenchPipeline {
    bgcolor="#2E2E2E";
    node [shape=box, style="rounded,filled", fontname="Helvetica", color="#B0B0B0", fillcolor="#4E4E4E", fontcolor="#FFFFFF"];
    edge [color="#B0B0B0", fontcolor="#FFFFFF"];
    rankdir=TB;

    subgraph cluster_pipeline {
        label="QA Bench Pipeline";
        style="rounded,filled";
        color="#383838";
        fontcolor="#FFFFFF";

        pipeline [label="qabench_pipeline.py\n(Main Orchestrator)"];
        answerer [label="qabench_answerer.py\n(Answers a single question)"];
        cli_runner [label="gemini_cli_runner.py\n(Runs the gemini-cli command)"];
        key_rotator [label="gemini_key_rotator.py\n(Manages API Keys)"];
    }

    pipeline -> answerer [label="calls via subprocess"];
    answerer -> cli_runner [label="imports and calls\nrun_gemini_cli_async"];
    cli_runner -> key_rotator [label="imports and uses\nGeminiKeyRotator\n(async with rotator as key:)"];

    subgraph cluster_key_usage {
        label="Key Rotator Usage";
        style="rounded,filled";
        color="#404040";
        fontcolor="#FFFFFF";
        acquire [label="_acquire_key()\n(Logs 'Task acquired key...')"];
        release [label="_release_key()\n(Logs 'Task releasing key...')"];
    }

    key_rotator -> acquire [label="is used by"];
    key_rotator -> release [label="is used by"];
}
